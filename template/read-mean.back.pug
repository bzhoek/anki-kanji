include _mixins
+main(color, mode, 'back')
  .top
    +field('picture')
    +text
      +optional('#kanji')
        +heading('furigana')
      +optional('^kanji')
        +heading('kana')
      +title('meaning')
      +optional('#kanji')
        +field('kana')
      +field('target')
  +optional('#kanji')
    +audioheader(grammar[0])
  +optional('^kanji')
    +audioheader(grammar[1] || grammar[0])
  +fields('notes', 'strokes', 'details')
