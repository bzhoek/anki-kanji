script.
  Array.from(document.getElementsByClassName("cloze")).forEach(tag => {
    tag.onclick = function () {
      tag.style.color = '#268bd2'
    }
  })

  function replaceText(query, regex, replacement) {
    Array.from(document.querySelectorAll(query)).forEach(tag => {
      tag.innerHTML = tag.innerHTML.replaceAll(regex, replacement)
    })
  }
  
  const KANJI = "\\u4E00-\\u9FFF"; // x4E00 - x9FFF: cjk unified ideographs
  const KANA = "\\u3000-\\u30FF"; // x3000 - x30FF: punctuation, hiragana and katakana
  const SYMBOLS = "◈◇◆▣□■△⨹⧊▲⨀⏜▬⧨⨺";
  
  setTimeout(function () {
    const terms = new RegExp("(<b>[\\u00BF-\\u00FF\\w\\s,'/-]+</b>)\\s+([\\u2E80-\\u9FFFｲ𧘇𠂉𡗗𠦝丿十卄]+)", 'gi')
    replaceText(".notes", terms, "<b>$1</b>&nbsp;<span class='part'>$2</span>")
    const kanja = new RegExp(`([${KANJI}${KANA}]+)`, 'gi')
    replaceText(".details", kanja, "<em>$1</em>")
    const symbols = new RegExp(`\\s+([${SYMBOLS}]+)`, 'gi')
    replaceText("h1, .listening", symbols, "<span class='type'>$1</span>")
    // wrap trailing kana and symbols in meaning
    const kana = new RegExp(`\\s+(<.+?>)?([${KANA}${SYMBOLS}]+)(</.+?>)?$`, 'gi')
    replaceText(".meaning", kana, "&nbsp;$1<span class='type'>$2</span>$3")

    const elementToMove = document.querySelector('.audio');
    const targetContainer = document.querySelector('main.back');
    if (elementToMove && targetContainer) {
      targetContainer.appendChild(elementToMove);
    }
  }, 400)
